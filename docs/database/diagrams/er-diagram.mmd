    profiles }o--|| countries : "país residencia"
    profiles }o--|| occupations : "ocupación"
    profiles }o--|| currencies : "moneda principal"

    profiles ||--o{ accounts : "posee"
    profiles ||--o{ crypto_holdings : "posee"
    profiles ||--o{ transactions : "registra"
    profiles ||--o{ categories : "crea (custom)"
    profiles ||--o{ tags : "crea"

    accounts }o--|| currencies : "denominada en"
    accounts }o--|| account_types : "tipo"
    accounts }o--|| financial_institutions : "institución (opcional)"

    crypto_holdings }o--|| crypto_assets : "activo"

    transactions ||--|{ transaction_entries : "compone"
    transactions }o--|| categories : "clasifica"
    transactions }o--o{ transaction_tags : "etiqueta"
    transactions }o--|| exchange_rates : "tasa usada (opcional)"

    transaction_entries }o--o| accounts : "afecta cuenta fiat"
    transaction_entries }o--o| crypto_holdings : "afecta cuenta cripto"
